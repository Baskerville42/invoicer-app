{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/main", "src/features", "src/shared"],
  "exclude": ["src/renderer", "src/features/*/renderer", "src/shared/components"]
}
